@model GodivaShop.Web.Models.Domain.Product
@{
    ViewData["Title"] = Model.Name;
}

@section Styles {
    <style>
        .main-image { width: 100%; height: 480px; object-fit: cover; transition: opacity 0.3s; }
        .thumbnail-strip img { width: 80px; height: 80px; object-fit: cover; cursor: pointer; border: 2px solid transparent; transition: border-color 0.2s; }
        .thumbnail-strip img:hover, .thumbnail-strip img.active { border-color: var(--gold); }
        .variant-btn { border: 1px solid #ddd; background: #fff; padding: 8px 20px; font-size: 0.8rem; letter-spacing: 1px; transition: all 0.2s; }
        .variant-btn.active, .variant-btn:hover { border-color: var(--gold); background: var(--gold); color: #fff; }
        .price-display { font-size: 1.8rem; color: var(--gold); font-family: 'Playfair Display', serif; transition: opacity 0.3s; }
        .accordion-button:not(.collapsed) { color: var(--gold); box-shadow: none; background: #fff; }
        .accordion-button:focus { box-shadow: none; }
        .accordion-item { border: none; border-bottom: 1px solid #eee; }
    </style>
}

<div class="container py-5">
    <div class="row g-5">
        <!-- CỘT TRÁI: GALLERY -->
        <div class="col-md-6">
            <img id="mainImage"
                 src="@Url.Content(Model.Images.FirstOrDefault(i => i.IsMain)?.ImagePath ?? Model.Images.FirstOrDefault()?.ImagePath ?? "~/images/no-image.jpg")"
                 class="main-image mb-3"
                 onerror="this.src='https://images.unsplash.com/photo-1549007994-cb92caebd54b?w=600'">

            <div class="thumbnail-strip d-flex gap-2 flex-wrap">
                @foreach (var img in Model.Images)
                {
                    <img src="@Url.Content(img.ImagePath)"
                         class="thumbnail @(img.IsMain ? "active" : "")"
                         onclick="changeMainImage(this, '@Url.Content(img.ImagePath)')"
                         onerror="this.src='https://images.unsplash.com/photo-1549007994-cb92caebd54b?w=80'">
                }
            </div>
        </div>

        <!-- CỘT PHẢI: THÔNG TIN -->
        <div class="col-md-6">
            <p class="text-muted small text-uppercase letter-spacing-2 mb-1">@Model.Category?.Name</p>
            <h1 class="serif mb-3" style="font-size:2.2rem;">@Model.Name</h1>

            <!-- GIÁ -->
            <div class="price-display mb-4" id="priceDisplay">
                @Model.BasePrice.ToString("N0") VNĐ
            </div>

            <!-- BIẾN THỂ -->
@if (Model.Variants != null && Model.Variants.Any())
{
    <div class="mb-4">
        <p class="small text-uppercase mb-2"
           style="letter-spacing:2px; font-weight:600; font-size:0.72rem;">
            Chọn số lượng:
        </p>
        <div class="d-flex gap-2 flex-wrap" id="variantGroup">
            @foreach (var variant in Model.Variants)
            {
                <button class="variant-btn"
                        data-variant-id="@variant.Id"
                        data-price="@variant.Price"
                        data-name="@variant.Name"
                        onclick="selectVariant(this, @variant.Id, @variant.Price)">
                    @variant.Name
                </button>
            }
        </div>
        <p class="text-muted mt-1 mb-0"
           style="font-size:0.72rem;">
            * Chọn biến thể để cập nhật giá
        </p>
    </div>
}
else
{
    <!-- Không có biến thể: hiển thị giá gốc bình thường -->
    <div class="mb-4">
        <p class="text-muted small">Sản phẩm không có biến thể</p>
    </div>
}

            <!-- CHỌN SỐ LƯỢNG -->
            <div class="mb-4">
                <p class="small text-uppercase" style="letter-spacing:2px; font-weight:600;">Số Lượng:</p>
                <div class="d-flex align-items-center gap-2">
                    <button class="btn btn-outline-secondary" id="qtyDecBtn" 
                            onclick="changeProductQty(-1)" style="width: 40px; height: 40px; padding: 0;">
                        <i class="fa fa-minus"></i>
                    </button>
                    <input type="number" id="productQty" class="form-control text-center" value="1" 
                           min="1" style="width: 70px; padding: 8px 4px;"
                           onchange="validateProductQty()">
                    <button class="btn btn-outline-secondary" id="qtyIncBtn" 
                            onclick="changeProductQty(1)" style="width: 40px; height: 40px; padding: 0;">
                        <i class="fa fa-plus"></i>
                    </button>
                </div>
            </div>

            <!-- LỜI CHÚC QUÀ TẶNG -->
            <div class="mb-4">
                <label class="small text-uppercase mb-2" style="letter-spacing:1px;">Lời Chúc (Tùy chọn)</label>
                <textarea id="giftMessage" class="form-control" rows="2" placeholder="Nhập lời chúc của bạn..."></textarea>
            </div>

            <!-- NÚT THÊM VÀO GIỎ -->
            <button onclick="addToCart(@Model.Id)" class="btn btn-gold w-100 py-3 mb-3"
                    style="letter-spacing:2px; text-transform:uppercase; font-size:0.85rem;">
                <i class="fa fa-shopping-bag me-2"></i> Thêm Vào Giỏ
            </button>

            <!-- ACCORDION MÔ TẢ -->
            <div class="accordion" id="productAccordion">
                <div class="accordion-item">
                    <h2 class="accordion-header">
                        <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#desc">
                            Mô Tả Sản Phẩm
                        </button>
                    </h2>
                    <div id="desc" class="accordion-collapse collapse show">
                        <div class="accordion-body small text-muted">@Model.Description</div>
                    </div>
                </div>
                <div class="accordion-item">
                    <h2 class="accordion-header">
                        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#delivery">
                            Thông Tin Giao Hàng
                        </button>
                    </h2>
                    <div id="delivery" class="accordion-collapse collapse">
                        <div class="accordion-body small text-muted">
                            Giao hàng toàn quốc 2-5 ngày làm việc. Miễn phí vận chuyển cho đơn từ 500.000đ.
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    let selectedVariantId = null;

    // ===== ĐỔI ẢNH CHÍNH =====
    function changeMainImage(thumb, src) {
        document.querySelectorAll('.thumbnail').forEach(t => t.classList.remove('active'));
        thumb.classList.add('active');
        const mainImg = document.getElementById('mainImage');
        mainImg.style.opacity = '0';
        setTimeout(() => {
            mainImg.src = src;
            mainImg.style.opacity = '1';
            mainImg.style.transition = 'opacity 0.2s';
        }, 150);
    }

    // ===== CHỌN BIẾN THỂ =====
    function selectVariant(btn, variantId, price) {
        selectedVariantId = variantId;
        document.querySelectorAll('.variant-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');

        const priceEl = document.getElementById('priceDisplay');
        priceEl.style.opacity = '0';
        setTimeout(() => {
            priceEl.textContent = parseFloat(price).toLocaleString('vi-VN') + ' VNĐ';
            priceEl.style.opacity = '1';
            priceEl.style.transition = 'opacity 0.2s';
        }, 150);
    }

    // ===== TĂNG GIẢM SỐ LƯỢNG ← 2 HÀM CÒN THIẾU =====
    function changeProductQty(delta) {
        const input = document.getElementById('productQty');
        let val = parseInt(input.value) + delta;
        if (val < 1) val = 1;
        if (val > 99) val = 99;
        input.value = val;
    }

    function validateProductQty() {
        const input = document.getElementById('productQty');
        let val = parseInt(input.value);
        if (isNaN(val) || val < 1) input.value = 1;
        else if (val > 99) input.value = 99;
        else input.value = val;
    }

    // ===== THÊM VÀO GIỎ =====
    function addToCart(productId) {
        const priceText = document.getElementById('priceDisplay').textContent;
        const price     = parseFloat(priceText.replace(/[^0-9]/g, ''));
        const qty       = parseInt(document.getElementById('productQty').value) || 1; // ← sửa từ 1 thành đọc input
        const activeBtn = document.querySelector('.variant-btn.active');

        const data = {
            productId:    productId,
            variantId:    selectedVariantId,
            variantName:  activeBtn ? activeBtn.dataset.name : null,
            quantity:     qty,
            unitPrice:    price,
            productName:  '@Html.Raw(Model.Name.Replace("'", "\\'"))',
            productImage: document.getElementById('mainImage').src,
            giftMessage:  document.getElementById('giftMessage').value
        };

        fetch('/Product/AddToCart', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data)
        })
        .then(r => r.json())
        .then(res => {
            if (res.success) {
                // Cập nhật badge
                const badge = document.getElementById('cartBadge')
                           ?? document.querySelector('.cart-count');
                if (badge) {
                    badge.textContent = res.cartCount;
                    badge.style.display = res.cartCount > 0 ? 'flex' : 'none';
                }
                showToast('✓ Đã thêm ' + qty + ' sản phẩm vào giỏ!');
            }
        })
        .catch(err => console.error('AddToCart error:', err));
    }

    // ===== TOAST =====
    function showToast(msg) {
        const old = document.querySelector('.toast-godiva');
        if (old) old.remove();

        const t = document.createElement('div');
        t.className = 'toast-godiva';
        t.style.cssText = `position:fixed; bottom:24px; right:24px; z-index:9999;
            background:#1a1a1a; color:#fff; padding:12px 20px;
            border-left:3px solid #C1A35E; font-size:0.85rem;
            box-shadow:0 4px 15px rgba(0,0,0,0.2); transition:opacity 0.3s;`;
        t.textContent = msg;
        document.body.appendChild(t);
        setTimeout(() => { t.style.opacity = '0'; }, 2200);
        setTimeout(() => t.remove(), 2500);
    }
</script>
}