@model GodivaShop.Web.Models.Domain.ApplicationUser
@{
    ViewData["Title"] = "Cập nhật thông tin";
}

<div class="container py-5" style="margin-top: 2rem; margin-bottom: 5rem;">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow-sm border-0" style="border-radius: 0;">
                <div class="card-body p-5">
                    <div class="text-center mb-4">
                        <i class="fa fa-user-edit fa-2x text-gold mb-3" style="color: #C1A35E;"></i>
                        <h3 class="serif">Cập Nhật Thông Tin</h3>
                        <p class="text-muted small">Vui lòng điền thông tin chính xác để Godiva giao hàng đến bạn thuận tiện nhất.</p>
                    </div>

                    <form asp-action="Edit" method="post">
                        <div class="mb-3">
                            <label class="form-label text-muted small fw-bold" style="letter-spacing: 1px;">HỌ VÀ TÊN</label>
                            <input asp-for="FullName" class="form-control px-3 py-2" style="border-radius: 0; border: 1px solid #ddd;" placeholder="VD: Nguyễn Văn A" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label text-muted small fw-bold" style="letter-spacing: 1px;">SỐ ĐIỆN THOẠI</label>
                            <input asp-for="PhoneNumber" class="form-control px-3 py-2" style="border-radius: 0; border: 1px solid #ddd;" placeholder="VD: 0901234567" />
                        </div>

                        <div class="mb-4">
                            <label class="form-label text-muted small fw-bold" style="letter-spacing: 1px;">ĐỊA CHỈ GIAO HÀNG</label>
                            <textarea asp-for="Address" class="form-control px-3 py-2" rows="3" style="border-radius: 0; border: 1px solid #ddd;" placeholder="Số nhà, Tên đường, Phường/Xã, Quận/Huyện..."></textarea>
                        </div>

                        <div class="d-flex gap-3 mt-4">
                            <a asp-action="Index" class="btn btn-outline-dark w-50 py-2" style="border-radius: 0; letter-spacing: 1px; font-size: 0.85rem;">HỦY BỎ</a>
                            <button type="submit" class="btn btn-dark w-50 py-2" style="border-radius: 0; letter-spacing: 1px; font-size: 0.85rem;">LƯU THAY ĐỔI</button>
                        </div>
                    </form>
                    <hr class="mt-5 mb-4">
                    <div class="text-center">
                        <p class="text-muted small mb-2">Bạn không muốn sử dụng tài khoản này nữa?</p>
                        <button type="button" class="btn btn-outline-danger btn-sm px-4 py-2" data-bs-toggle="modal" data-bs-target="#deleteAccountModal" style="border-radius: 0; letter-spacing: 1px;">
                            XÓA TÀI KHOẢN
                        </button>
                    </div>

                    <div class="modal fade" id="deleteAccountModal" tabindex="-1">
                        <div class="modal-dialog modal-dialog-centered">
                            <div class="modal-content" style="border-radius: 0;">
                                <div class="modal-header border-0 pb-0">
                                    <h5 class="serif text-danger">Cảnh báo xóa tài khoản</h5>
                                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                </div>
                                <div class="modal-body text-center">
                                    <i class="fa fa-exclamation-triangle fa-3x text-danger mb-3"></i>
                                    <p class="text-muted small mb-2">Hành động này <strong>không thể hoàn tác</strong>. Mọi thông tin cá nhân và điểm tích lũy của bạn sẽ bị xóa vĩnh viễn.</p>
                                    <p class="text-muted small">Lịch sử đơn hàng cũ sẽ được lưu dưới dạng khách vãng lai.</p>
                                </div>
                                <div class="modal-footer border-0 d-flex gap-2 justify-content-center">
                                    <button type="button" class="btn btn-light w-25" data-bs-dismiss="modal" style="border-radius: 0;">HỦY</button>
                                    
                                    <form asp-action="DeleteAccount" method="post" class="w-50">
                                        <button type="submit" class="btn btn-danger w-100" style="border-radius: 0; letter-spacing: 1px;">TÔI CHẮC CHẮN XÓA</button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>