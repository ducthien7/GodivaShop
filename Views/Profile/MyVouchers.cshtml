@model IEnumerable<GodivaShop.Web.Models.Domain.Coupon>
@{
    ViewData["Title"] = "Kho Voucher Của Tôi";
}

<div class="container py-5">
    <div class="d-flex align-items-center mb-4">
        <a href="/Profile/Index" class="text-muted me-3"><i class="fa fa-arrow-left"></i> Quay lại</a>
        <h3 class="serif text-gold mb-0">Kho Voucher Của Bạn</h3>
    </div>

    <div class="row">
        @if (!Model.Any())
        {
            <div class="col-12 text-center py-5" style="background: #fdf9f0; border: 1px dashed #C1A35E;">
                <i class="fa fa-ticket-alt text-muted mb-3" style="font-size: 3rem;"></i>
                <p class="text-muted">Bạn chưa có mã giảm giá nào.</p>
                <a href="/Gift/Index" class="btn btn-gold mt-2">Đến Vòng Quay May Mắn ngay!</a>
            </div>
        }
        
        @foreach (var v in Model)
        {
            <div class="col-md-4 mb-3">
                <div class="card border-0 shadow-sm h-100" style="border-left: 5px solid #C1A35E !important;">
                    <div class="card-body">
                        <div class="d-flex justify-content-between">
                            <h5 class="card-title text-gold fw-bold">
                                @(v.DiscountType == GodivaShop.Web.Models.Domain.DiscountType.Percentage ? $"-{v.DiscountValue}%" : $"-{v.DiscountValue:N0}đ")
                            </h5>
                            <span class="badge bg-light text-dark border">x1</span>
                        </div>
                        <p class="mb-1" style="font-size: 0.9rem;">Mã Code: <strong class="text-dark" id="code-@v.Code">@v.Code</strong></p>
                        <small class="text-muted" style="font-size: 0.8rem;">
                            <i class="fa fa-clock me-1"></i> HSD: @(v.ExpiryDate?.ToString("dd/MM/yyyy HH:mm") ?? "Không giới hạn")
                        </small>
                        <div class="mt-3">
                            <button onclick="copyCode('@v.Code')" class="btn btn-sm btn-outline-gold w-100">
                                <i class="fa fa-copy me-1"></i> Sao chép mã
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        function copyCode(code) {
            navigator.clipboard.writeText(code).then(() => {
                alert("Đã sao chép mã: " + code);
            });
        }
    </script>
}