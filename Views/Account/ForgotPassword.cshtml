@{
    ViewData["Title"] = "Quên mật khẩu";
}

<div class="container py-5" style="margin-top: 3rem; margin-bottom: 5rem;">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow-sm border-0" style="border-radius: 0;">
                <div class="card-body p-5 text-center">
                    <i class="fa fa-envelope-open-text fa-3x mb-3" style="color: #C1A35E;"></i>
                    <h4 class="serif mb-3">Khôi phục mật khẩu</h4>
                    <p class="text-muted small mb-4">Nhập email bạn đã đăng ký. Chúng tôi sẽ gửi một liên kết an toàn để bạn đặt lại mật khẩu.</p>

                    @if (ViewBag.Message != null)
                    {
                        <div class="alert alert-success small">@ViewBag.Message</div>
                        
                        @if (ViewBag.TestLink != null)
                        {
                            <div class="alert alert-warning text-start mt-3" style="word-break: break-all; font-size: 0.8rem;">
                                <strong>[Góc Dành Cho Dev]</strong> Click vào link này để đổi mật khẩu: <br />
                                <a href="@ViewBag.TestLink" class="fw-bold text-danger">Bấm vào đây để Đổi mật khẩu</a>
                            </div>
                        }
                    }
                    else
                    {
                        <form asp-action="ForgotPassword" method="post">
                            <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>
                            <div class="mb-4 text-start">
                                <label class="form-label small fw-bold text-muted" style="letter-spacing: 1px;">ĐỊA CHỈ EMAIL</label>
                                <input type="email" name="email" class="form-control px-3 py-2" style="border-radius: 0;" placeholder="Ví dụ: fcb@mailer.com" required />
                            </div>
                            <button type="submit" class="btn btn-dark w-100 py-2" style="border-radius: 0; letter-spacing: 1px; font-size: 0.85rem;">GỬI LIÊN KẾT KHÔI PHỤC</button>
                        </form>
                    }
                    
                    <div class="mt-4">
                        <a href="/Identity/Account/Login" class="text-muted small text-decoration-none"><i class="fa fa-arrow-left me-1"></i> Quay lại Đăng nhập</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>