@{
    ViewData["Title"] = "Đặt lại mật khẩu";
}

<div class="container py-5" style="margin-top: 3rem; margin-bottom: 5rem;">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow-sm border-0" style="border-radius: 0;">
                <div class="card-body p-5">
                    <h4 class="serif mb-4 text-center">Tạo Mật Khẩu Mới</h4>
                    
                    <form asp-action="ResetPassword" method="post">
                        <div asp-validation-summary="All" class="text-danger small mb-3"></div>
                        
                        <input type="hidden" name="token" value="@ViewBag.Token" />
                        <input type="hidden" name="email" value="@ViewBag.Email" />

                        <div class="mb-3">
                            <label class="form-label small fw-bold text-muted" style="letter-spacing: 1px;">MẬT KHẨU MỚI</label>
                            <input type="password" name="newPassword" class="form-control px-3 py-2" style="border-radius: 0;" required />
                            <small class="text-muted" style="font-size: 0.7rem;">Ít nhất 6 ký tự, gồm chữ hoa, chữ thường, số và ký tự đặc biệt.</small>
                        </div>
                        <div class="mb-4">
                            <label class="form-label small fw-bold text-muted" style="letter-spacing: 1px;">XÁC NHẬN MẬT KHẨU</label>
                            <input type="password" name="confirmPassword" class="form-control px-3 py-2" style="border-radius: 0;" required />
                        </div>

                        <button type="submit" class="btn btn-dark w-100 py-2" style="border-radius: 0; letter-spacing: 1px; font-size: 0.85rem;">LƯU MẬT KHẨU</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>