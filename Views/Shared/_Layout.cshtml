<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Godiva</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Lato:wght@300;400;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --gold: #C1A35E;
            --gold-light: #d4b97a;
            --dark: #1a1a1a;
        }

        *, *::before, *::after {
            box-sizing: border-box;
        }

        html, body {
            height: 100%;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Lato', sans-serif;
            background: #fff;
            color: var(--dark);
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        /* TYPOGRAPHY */
        .serif {
            font-family: 'Playfair Display', serif;
        }

        .text-gold {
            color: var(--gold) !important;
        }

        .bg-gold {
            background-color: var(--gold) !important;
        }

        /* BUTTONS */
        .btn-gold {
            background-color: var(--gold);
            color: #fff !important;
            border: none;
            font-family: 'Lato', sans-serif;
            letter-spacing: 1px;
            transition: background 0.3s;
            border-radius: 0;
        }

            .btn-gold:hover {
                background-color: var(--gold-light);
                color: #fff !important;
            }

        .btn-outline-gold {
            border: 1px solid var(--gold);
            color: var(--gold) !important;
            background: transparent;
            border-radius: 0;
            transition: all 0.3s;
        }

            .btn-outline-gold:hover {
                background-color: var(--gold);
                color: #fff !important;
            }

        /* NAVBAR */
        .navbar {
            background: #fff;
            border-bottom: 1px solid #f0ebe0;
            padding: 0 2rem;
            min-height: 70px;
            position: sticky;
            top: 0;
            z-index: 1030;
        }

        .navbar-brand {
            font-family: 'Playfair Display', serif;
            font-size: 1.8rem;
            color: var(--gold) !important;
            letter-spacing: 3px;
            text-transform: uppercase;
            text-decoration: none;
        }

        .nav-link {
            font-size: 0.82rem;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            color: var(--dark) !important;
            padding: 0 1rem !important;
            font-weight: 400;
            transition: color 0.2s;
            text-decoration: none;
        }

            .nav-link:hover {
                color: var(--gold) !important;
            }

        .navbar-nav {
            height: 70px;
            align-items: center;
        }

        /* MEGA MENU */
        .mega-menu {
            position: absolute;
            top: 100%;
            left: 50%;
            transform: translateX(-50%);
            background: #fff;
            border-top: 2px solid var(--gold);
            min-width: 420px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
            display: none;
            z-index: 9999;
            padding: 1.5rem 2rem;
            gap: 2rem;
        }

        .nav-item:hover .mega-menu {
            display: flex;
        }

        .mega-menu a {
            font-size: 0.78rem;
            letter-spacing: 1px;
            text-transform: uppercase;
            color: var(--dark) !important;
            text-decoration: none;
            display: block;
            padding: 5px 0;
            transition: color 0.2s;
        }

            .mega-menu a:hover {
                color: var(--gold) !important;
            }

        /* NAV ICONS */
        .nav-icon {
            font-size: 1rem;
            color: var(--dark) !important;
            transition: color 0.3s;
            text-decoration: none;
        }

            .nav-icon:hover {
                color: var(--gold) !important;
            }

        .cart-count {
            background: var(--gold);
            color: #fff;
            font-size: 0.6rem;
            width: 17px;
            height: 17px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            position: absolute;
            top: -6px;
            right: -8px;
            font-weight: 700;
        }

        /* MAIN */
        main {
            flex: 1 0 auto;
        }

        /* FOOTER */
        .site-footer {
            flex-shrink: 0;
            background-color: #1a1a1a !important;
            color: #ccc !important;
            padding: 4rem 0 2rem;
        }

            .site-footer .footer-brand {
                font-family: 'Playfair Display', serif;
                font-size: 1.6rem;
                color: var(--gold) !important;
                letter-spacing: 3px;
                display: block;
                margin-bottom: 1rem;
            }

            .site-footer .footer-desc {
                color: #999 !important;
                font-size: 0.85rem;
                line-height: 1.7;
            }

            .site-footer .footer-heading {
                color: var(--gold) !important;
                font-size: 0.7rem;
                letter-spacing: 2px;
                text-transform: uppercase;
                margin-bottom: 1rem;
                font-weight: 600;
            }

            .site-footer .footer-link {
                color: #bbb !important;
                text-decoration: none;
                font-size: 0.85rem;
                display: block;
                padding: 3px 0;
                transition: color 0.2s;
            }

                .site-footer .footer-link:hover {
                    color: var(--gold) !important;
                }

            .site-footer .footer-contact {
                color: #bbb !important;
                font-size: 0.85rem;
            }

            .site-footer .footer-bottom {
                border-top: 1px solid #333;
                margin-top: 2rem;
                padding-top: 1.5rem;
                color: #666 !important;
                font-size: 0.78rem;
                text-align: center;
            }

            .site-footer .footer-social a {
                color: #888 !important;
                font-size: 1rem;
                margin-right: 12px;
                transition: color 0.2s;
                text-decoration: none;
            }

                .site-footer .footer-social a:hover {
                    color: var(--gold) !important;
                }

        /* DROPDOWN */
        .dropdown-menu {
            border-radius: 0;
            border: none;
            box-shadow: 0 8px 24px rgba(0,0,0,0.1);
            font-size: 0.82rem;
        }

        .dropdown-item:hover {
            background: #faf8f5;
            color: var(--gold);
        }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

    <!-- ===== NAVBAR ===== -->
    <nav class="navbar navbar-expand-lg">
        <div class="container-xl">

            <!-- TRÁI: Brand — thêm asp-area="" -->
            <a class="navbar-brand"
               asp-area=""
               asp-controller="Home"
               asp-action="Index">GODIVA</a>

            <button class="navbar-toggler border-0" type="button"
                    data-bs-toggle="collapse" data-bs-target="#navMain">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navMain">

                <!-- GIỮA: Menu chính -->
                <ul class="navbar-nav mx-auto" style="height:70px; align-items:center;">

                    <li class="nav-item">
                        <a class="nav-link"
                           asp-area=""
                           asp-controller="Product"
                           asp-action="Category">
                            Bán Chạy Nhất
                        </a>
                    </li>

                    <!-- Chocolates + Mega Menu -->
                    <li class="nav-item position-relative">
                        <a class="nav-link" href="#">Chocolates</a>
                        <div class="mega-menu">
                            <div>
                                <a asp-area=""
                                   asp-controller="Product"
                                   asp-action="Category"
                                   asp-route-slug="assorted">
                                    Assorted Chocolates
                                </a>
                                <a asp-area=""
                                   asp-controller="Product"
                                   asp-action="Category"
                                   asp-route-slug="dark-chocolate">
                                    Dark Chocolate
                                </a>
                            </div>
                            <div>
                                <a asp-area=""
                                   asp-controller="Product"
                                   asp-action="Category"
                                   asp-route-slug="milk-chocolate">
                                    Milk Chocolate
                                </a>
                                <a asp-area=""
                                   asp-controller="Product"
                                   asp-action="Category"
                                   asp-route-slug="kosher">
                                    Kosher Chocolate
                                </a>
                            </div>
                        </div>
                    </li>

                    <li class="nav-item">
                        <a asp-controller="Gift" asp-action="Index" class="nav-link">Quà tặng</a>
                    </li>
                    <li class="nav-item">
                        <a asp-controller="Home" asp-action="OurStory" class="nav-link">Về chúng tôi</a>
                    </li>

                </ul>

                <!-- PHẢI: Icons -->
                <div class="d-flex align-items-center gap-3">

                    <!-- Thay thế <a href="#" class="nav-icon"> -->
                    <button onclick="openSearch()"
                            class="nav-icon"
                            style="background:none; border:none; padding:0; cursor:pointer;">
                        <i class="fa fa-search"></i>
                    </button>

                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <div class="dropdown">
                            <a href="#" class="nav-icon" data-bs-toggle="dropdown">
                                <i class="fa fa-user"></i>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end">
                                @if (User.IsInRole("Admin") || User.IsInRole("Staff"))
                                {
                                    <li>
                                        <a class="dropdown-item"
                                           asp-area="Admin"
                                           asp-controller="Dashboard"
                                           asp-action="Index">
                                            <i class="fa fa-chart-bar me-2 text-gold"></i>Admin Panel
                                        </a>
                                    </li>
                                    <li><hr class="dropdown-divider"></li>
                                }
                                <li>
                                    <span class="dropdown-item-text small text-muted px-3">
                                        @User.Identity?.Name
                                    </span>
                                </li>
                                <li>
                                    <form action="/Identity/Account/Logout" method="post">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="dropdown-item"
                                                style="font-size:0.8rem;">
                                            <i class="fa fa-sign-out-alt me-2"></i>Đăng Xuất
                                        </button>
                                    </form>
                                </li>
                            </ul>
                        </div>
                    }
                    else
                    {
                        <a href="/Identity/Account/Login" class="nav-icon">
                            <i class="fa fa-user"></i>
                        </a>
                    }

                    <!-- Cart -->
                    <a asp-area=""
                       asp-controller="Cart"
                       asp-action="Index"
                       class="nav-icon position-relative">
                        <i class="fa fa-shopping-bag"></i>
                        @{
                            var cartCount = ViewBag.CartCount as int? ?? 0;
                        }
                        @if (cartCount > 0)
                        {
                            <span class="cart-count">@cartCount</span>
                        }
                    </a>

                </div>
                <!-- KẾT THÚC: Icons -->

            </div>
            <!-- KẾT THÚC: collapse navbar-collapse -->

        </div>
        <!-- KẾT THÚC: container-xl -->
    </nav>
    <!-- KẾT THÚC: NAVBAR -->
    <!-- ===== MAIN CONTENT ===== -->
    <main>
        @RenderBody()
    </main>


    <!-- ===== FOOTER ===== -->
    <footer class="site-footer">
        <div class="container">
            <div class="row g-4">

                <!-- CỘT 1: Brand -->
                <div class="col-lg-4 col-md-6">
                    <span class="footer-brand">GODIVA</span>
                    <p class="footer-desc">
                        Thương hiệu chocolate sang trọng từ năm 1926.<br>
                        Mang đến những hộp quà tinh tế và đẳng cấp nhất.
                    </p>
                    <div class="footer-social mt-3">
                        <a href="#"><i class="fab fa-facebook-f"></i></a>
                        <a href="#"><i class="fab fa-instagram"></i></a>
                        <a href="#"><i class="fab fa-youtube"></i></a>
                    </div>
                </div>

                <!-- CỘT 2: Sản phẩm — thêm asp-area="" -->
                <div class="col-lg-2 col-md-3 col-6">
                    <p class="footer-heading">Sản Phẩm</p>
                    <a asp-area=""
                       asp-controller="Product"
                       asp-action="Category"
                       asp-route-slug="assorted"
                       class="footer-link">Assorted Chocolate</a>
                    <a asp-area=""
                       asp-controller="Product"
                       asp-action="Category"
                       asp-route-slug="dark-chocolate"
                       class="footer-link">Dark Chocolate</a>
                    <a asp-area=""
                       asp-controller="Product"
                       asp-action="Category"
                       asp-route-slug="milk-chocolate"
                       class="footer-link">Milk Chocolate</a>
                    <a href="#" class="footer-link">Quà Tặng</a>
                </div>

                <!-- CỘT 3: Hỗ trợ -->
                <div class="col-lg-2 col-md-3 col-6">
                    <p class="footer-heading">Hỗ Trợ</p>
                    <a href="#" class="footer-link">Về Chúng Tôi</a>
                    <a href="#" class="footer-link">Chính Sách Bảo Mật</a>
                    <a href="#" class="footer-link">Điều Khoản Dịch Vụ</a>
                    <a href="#" class="footer-link">Hướng Dẫn Mua Hàng</a>
                </div>

                <!-- CỘT 4: Liên hệ + Newsletter -->
                <div class="col-lg-4 col-md-6">
                    <p class="footer-heading">Liên Hệ</p>
                    <p class="footer-contact mb-2">
                        <i class="fa fa-envelope me-2" style="color:var(--gold);"></i>
                        support@godiva.vn
                    </p>
                    <p class="footer-contact mb-2">
                        <i class="fa fa-phone me-2" style="color:var(--gold);"></i>
                        1800 6868
                    </p>
                    <p class="footer-contact mb-3">
                        <i class="fa fa-map-marker-alt me-2" style="color:var(--gold);"></i>
                        123 Nguyễn Huệ, Q.1, TP.HCM
                    </p>
                    <div class="input-group" style="max-width:300px;">
                        <input type="email" class="form-control"
                               style="border-radius:0; border-color:#333;
                                  background:#2a2a2a; color:#ccc; font-size:0.8rem;"
                               placeholder="Email của bạn...">
                        <button class="btn btn-gold"
