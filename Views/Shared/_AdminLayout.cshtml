@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin — @ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600&family=Lato:wght@300;400;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --gold: #C1A35E;
            --sidebar-w: 240px;
            --dark: #1a1a1a;
        }

        body {
            font-family: 'Lato', sans-serif;
            background: #f4f3f1;
            margin: 0;
        }

        .serif {
            font-family: 'Playfair Display', serif;
        }

        .text-gold {
            color: var(--gold) !important;
        }

        /* SIDEBAR */
        .sidebar {
            width: var(--sidebar-w);
            height: 100vh;
            position: fixed;
            top: 0;
            left: 0;
            background: var(--dark);
            display: flex;
            flex-direction: column;
            z-index: 1000;
        }

        .sidebar-brand {
            padding: 1.5rem;
            text-align: center;
            border-bottom: 1px solid #333;
            font-family: 'Playfair Display', serif;
            font-size: 1.4rem;
            color: var(--gold);
            letter-spacing: 3px;
        }

            .sidebar-brand small {
                display: block;
                font-size: 0.55rem;
                color: #888;
                letter-spacing: 2px;
                text-transform: uppercase;
                margin-top: 4px;
            }

        .sidebar-nav {
            padding: 1rem 0;
            flex: 1;
            overflow-y: auto;
        }

        .nav-section {
            padding: 1rem 1.2rem 0.3rem;
            font-size: 0.6rem;
            color: #666;
            letter-spacing: 2px;
            text-transform: uppercase;
        }

        .sidebar-nav .nav-link {
            padding: 10px 1.5rem;
            font-size: 0.8rem;
            color: #bbb;
            display: flex;
            align-items: center;
            gap: 10px;
            transition: all 0.2s;
            border-left: 3px solid transparent;
            letter-spacing: 0.5px;
            text-decoration: none;
        }

            .sidebar-nav .nav-link:hover,
            .sidebar-nav .nav-link.active {
                color: #fff;
                border-left-color: var(--gold);
                background: rgba(193,163,94,0.08);
            }

            .sidebar-nav .nav-link i {
                width: 16px;
                text-align: center;
            }

        .sidebar-footer {
            padding: 1rem 1.5rem;
            border-top: 1px solid #333;
        }

            .sidebar-footer a {
                font-size: 0.75rem;
                color: #888;
                text-decoration: none;
                display: flex;
                align-items: center;
                gap: 8px;
            }

                .sidebar-footer a:hover {
                    color: var(--gold);
                }

        /* MAIN */
        .admin-main {
            margin-left: var(--sidebar-w);
            min-height: 100vh;
        }

        .admin-topbar {
            background: #fff;
            border-bottom: 1px solid #eee;
            padding: 0 2rem;
            height: 60px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            position: sticky;
            top: 0;
            z-index: 999;
        }

            .admin-topbar .page-title {
                font-size: 0.85rem;
                font-weight: 700;
                letter-spacing: 2px;
                text-transform: uppercase;
                color: #333;
            }

        .admin-content {
            padding: 2rem;
        }

        /* CARDS */
        .stat-card {
            background: #fff;
            border: none;
            border-radius: 0;
            padding: 1.5rem;
            border-left: 3px solid var(--gold);
        }

            .stat-card .stat-num {
                font-family: 'Playfair Display', serif;
                font-size: 2rem;
                color: var(--gold);
                line-height: 1;
            }

            .stat-card .stat-label {
                font-size: 0.7rem;
                letter-spacing: 1.5px;
                text-transform: uppercase;
                color: #999;
                margin-top: 4px;
            }

        /* TABLE */
        .admin-table {
            background: #fff;
        }

            .admin-table thead th {
                background: var(--dark);
                color: #fff;
                font-size: 0.7rem;
                letter-spacing: 1.5px;
                text-transform: uppercase;
                font-weight: 400;
                padding: 1rem;
                border: none;
            }

            .admin-table tbody td {
                font-size: 0.85rem;
                padding: 0.85rem 1rem;
                border-color: #f0ede8;
                vertical-align: middle;
            }

            .admin-table tbody tr:hover td {
                background: #faf8f5;
            }

        /* BADGE STATUS */
        .badge-status {
            font-size: 0.65rem;
            letter-spacing: 1px;
            padding: 4px 10px;
            border-radius: 20px;
            text-transform: uppercase;
            font-weight: 400;
        }

        .badge-pending {
            background: #fff3cd;
            color: #856404;
        }

        .badge-confirmed {
            background: #cce5ff;
            color: #004085;
        }

        .badge-shipped {
            background: #d4edda;
            color: #155724;
        }

        .badge-cancelled {
            background: #f8d7da;
            color: #721c24;
        }

        .badge-delivered {
            background: #d1ecf1;
            color: #0c5460;
        }

        .badge-processing {
            background: #e2d9f3;
            color: #432874;
        }

        /* FORM */
        .admin-form-control {
            border-radius: 0;
            border: 1px solid #ddd;
            font-size: 0.875rem;
        }

            .admin-form-control:focus {
                border-color: var(--gold);
                box-shadow: 0 0 0 2px rgba(193,163,94,0.15);
            }

        .btn-admin-gold {
            background: var(--gold);
            color: #fff;
            border: none;
            border-radius: 0;
            font-size: 0.8rem;
            letter-spacing: 1px;
            text-transform: uppercase;
            padding: 8px 20px;
        }

            .btn-admin-gold:hover {
                background: #d4b97a;
                color: #fff;
            }

        .btn-admin-outline {
            border: 1px solid var(--gold);
            color: var(--gold);
            background: transparent;
            border-radius: 0;
            font-size: 0.8rem;
            padding: 6px 16px;
        }

            .btn-admin-outline:hover {
                background: var(--gold);
                color: #fff;
            }

        /* NOTIFICATION */
        #notifDropdown {
            position: absolute;
            right: 0;
            top: 130%;
            width: 320px;
            background: #fff;
            box-shadow: 0 10px 30px rgba(0,0,0,0.12);
            z-index: 9999;
            max-height: 400px;
            overflow-y: auto;
        }

            #notifDropdown .notif-item {
                padding: 12px 16px;
                border-bottom: 1px solid #f5f5f5;
                font-size: 0.8rem;
            }

                #notifDropdown .notif-item:hover {
                    background: #faf8f5;
                }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

    <!-- SIDEBAR -->
    <aside class="sidebar">
        <div class="sidebar-brand">
            GODIVA
            <small>Admin Panel</small>
        </div>
        <nav class="sidebar-nav">
            <p class="nav-section">Tổng Quan</p>
            <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index"
               class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "active" : "")">
                <i class="fa fa-chart-bar"></i> Dashboard
            </a>

            <p class="nav-section">Quản Lý</p>
            <a asp-area="Admin" asp-controller="Order" asp-action="Index"
               class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Order" ? "active" : "")">
                <i class="fa fa-shopping-bag"></i> Đơn Hàng
            </a>
            <a asp-area="Admin" asp-controller="Product" asp-action="Index"
               class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Product" ? "active" : "")">
                <i class="fa fa-box"></i> Sản Phẩm
            </a>
            <a asp-area="Admin" asp-controller="Category" asp-action="Index"
               class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Category" ? "active" : "")">
                <i class="fa fa-tags"></i> Danh Mục
            </a>
            <a asp-area="Admin" asp-controller="Coupon" asp-action="Index"
               class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Coupon" ? "active" : "")">
                <i class="fa fa-ticket-alt"></i> Mã Giảm Giá
            </a>

            <p class="nav-section">Người Dùng</p>
            <a asp-area="Admin" asp-controller="User" asp-action="Index"
               class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "User" ? "active" : "")">
                <i class="fa fa-users"></i> Tài Khoản
            </a>
        </nav>
        <div class="sidebar-footer">
            <!-- Mở tab mới → không mất session admin -->
            <a href="/" target="_blank"
               style="font-size:0.75rem; color:#888; text-decoration:none;
              display:flex; align-items:center; gap:8px; padding:4px 0;
              transition:color 0.2s;">
                <i class="fa fa-external-link-alt"></i>
                Xem Website
            </a>
        </div>
    </aside>

    <!-- MAIN -->
    <div class="admin-main">
        <div class="admin-topbar">
            <span class="page-title">@ViewData["Title"]</span>
            <div class="d-flex align-items-center gap-3">
                <a href="/" target="_blank"
                   class="btn btn-sm"
                   style="border:1px solid #ddd; border-radius:0; font-size:0.72rem;
              color:#666; padding:4px 12px; text-decoration:none;">
                    <i class="fa fa-globe me-1"></i> Website
                </a>
                <!-- NOTIFICATION BELL -->
                <div class="position-relative" id="notifBell" onclick="toggleNotif()">
                    <i class="fa fa-bell" style="font-size:1rem; color:#555; cursor:pointer;"></i>
                    <span id="notifCount"
                          style="display:none; position:absolute; top:-6px; right:-8px;
                             background:#e74c3c; color:#fff; font-size:0.6rem;
                             width:16px; height:16px; border-radius:50%;
                             display:none; align-items:center; justify-content:center;">
                        0
                    </span>
                </div>
                <div id="notifDropdown" style="display:none;" class="position-absolute">
                    <div style="padding:10px 16px; border-bottom:1px solid #eee;
                            font-size:0.7rem; letter-spacing:1px;
                            text-transform:uppercase; color:#999;">
                        Đơn Hàng Mới
                    </div>
                    <div id="notifList">
                        <p class="text-muted small text-center p-3 mb-0">Chưa có thông báo</p>
                    </div>
                </div>

                <!-- USER -->
                <div class="dropdown">
                    <span class="small text-muted"
                          style="cursor:pointer;" data-bs-toggle="dropdown">
                        <i class="fa fa-user-circle me-1"></i>
                        @User.Identity?.Name
                    </span>
                    <ul class="dropdown-menu dropdown-menu-end"
                        style="border-radius:0; font-size:0.8rem;">
                        <li>
                            <form action="/Identity/Account/Logout" method="post">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="dropdown-item text-danger">
                                    <i class="fa fa-sign-out-alt me-2"></i>Đăng Xuất
                                </button>
                            </form>
                        </li>
                    </ul>
                </div>
            </div>
        </div>

        <div class="admin-content">
            @RenderBody()
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>
    <script src="https://cdn.microsoft.com/ajax/signalr/latest/dist/browser/signalr.min.js"></script>
    <script>
        // SignalR
        let notifCount = 0;
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/orderHub").build();

        connection.on("NewOrder", function (order) {
            notifCount++;
            const badge = order.isGuest
                ? '<span class="badge bg-secondary" style="font-size:0.6rem;">Guest</span>'
                : '<span class="badge bg-success" style="font-size:0.6rem;">Member</span>';
            const item = `
                    <div class="notif-item">
                        <strong>#${order.orderId}</strong> — ${order.customerName} ${badge}
                        <br><span style="color:var(--gold);">
                            ${order.amount.toLocaleString('vi-VN')}đ
                        </span>
                        <small class="text-muted float-end">
                            ${new Date().toLocaleTimeString('vi-VN')}
                        </small>
                    </div>`;
            if ($('#notifList p').length) $('#notifList').empty();
            $('#notifList').prepend(item);
            $('#notifCount').text(notifCount).css('display', 'flex');
        });

        connection.start()
            .then(() => connection.invoke("JoinAdminGroup"))
            .catch(err => console.error('SignalR:', err));

        function toggleNotif() {
            const d = $('#notifDropdown');
            d.toggle();
            if (d.is(':visible')) {
                notifCount = 0;
                $('#notifCount').hide();
            }
        }
        $(document).click(function (e) {
            if (!$(e.target).closest('#notifBell, #notifDropdown').length)
                $('#notifDropdown').hide();
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>