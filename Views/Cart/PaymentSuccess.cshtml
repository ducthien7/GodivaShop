@{
    ViewData["Title"] = "Thanh Toán Thành Công";
}

<div class="container py-5">
    <div class="text-center" style="min-height:60vh; display:flex; align-items:center; justify-content:center;">
        <div>
            <div style="width:100px;height:100px;border-radius:50%;background:linear-gradient(135deg,#C1A35E,#d4b97a);display:flex;align-items:center;justify-content:center;margin:0 auto 1rem;">
                <i class="fa fa-check" style="color:#fff;font-size:2.2rem"></i>
            </div>
            <h2 class="serif mb-2">Thanh Toán Thành Công!</h2>
            <p class="text-muted small mb-3">Cảm ơn bạn đã đặt hàng tại Godiva Chocolate.</p>
            @if (ViewBag.OrderId != null)
            {
                <div class="order-id" style="display:inline-block;background:#faf8f5;border:1px solid var(--gold);padding:8px 20px;color:var(--gold);font-family:'Playfair Display',serif;margin-bottom:1rem;">
                    Đơn hàng #@ViewBag.OrderId
                </div>
            }
            <div class="mt-4">
                <a asp-controller="Home" asp-action="Index" class="btn btn-outline-gold px-4 me-2">Về Trang Chủ</a>
                <a asp-controller="Product" asp-action="Category" class="btn btn-gold px-4">Tiếp Tục Mua Sắm</a>
            </div>
        </div>
    </div>
</div>
