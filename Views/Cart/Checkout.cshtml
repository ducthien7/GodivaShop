@model GodivaShop.Web.Models.ViewModels.CheckoutViewModel
@{
    ViewData["Title"] = "Thanh Toán";
}

<div class="container py-5">
    <h2 class="serif text-center mb-2">Thanh Toán</h2>
    <p class="text-center text-muted small mb-4">Vui lòng kiểm tra thông tin và xác nhận đơn hàng</p>

    <div class="row">
        <div class="col-md-7">
            <form asp-action="PlaceOrder" asp-controller="Cart" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                <div class="mb-3">
                    <label class="form-label">Họ tên</label>
                    <input asp-for="FullName" class="form-control" />
                    <span asp-validation-for="FullName" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label">Email</label>
                    <input asp-for="Email" class="form-control" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label">Số điện thoại</label>
                    <input asp-for="Phone" class="form-control" />
                    <span asp-validation-for="Phone" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label">Địa chỉ giao hàng</label>
                    <input asp-for="ShippingAddress" class="form-control" />
                    <span asp-validation-for="ShippingAddress" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label">Mã giảm giá (nếu có)</label>
                    <input asp-for="CouponCode" class="form-control" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Ghi chú</label>
                    <textarea asp-for="Note" class="form-control" rows="3"></textarea>
                </div>

                <button type="submit" class="btn btn-gold px-4 py-2">Xác nhận và Thanh toán</button>
            </form>
        </div>

        <div class="col-md-5">
            <div class="summary-box p-3">
                <h5 class="serif mb-3">Tóm tắt đơn hàng</h5>
                @if (Model.CartItems == null || !Model.CartItems.Any())
                {
                    <p class="text-muted small">Giỏ hàng trống</p>
                }
                else
                {
                    foreach (var item in Model.CartItems)
                    {
                        <div class="d-flex justify-content-between mb-2">
                            <div>
                                <div class="fw-semibold">@item.ProductName</div>
                                @if (!string.IsNullOrEmpty(item.VariantName)) { <div class="small text-muted">@item.VariantName</div> }
                                <div class="small text-muted">x@item.Quantity</div>
                            </div>
                            <div class="text-gold fw-semibold">@item.Subtotal.ToString("N0") VNĐ</div>
                        </div>
                    }
                    <hr />
                    <div class="d-flex justify-content-between">
                        <span>Tạm tính</span>
                        <span class="fw-semibold">@Model.TotalAmount.ToString("N0") VNĐ</span>
                    </div>
                    <div class="d-flex justify-content-between mt-2">
                        <span>Giảm giá</span>
                        <span class="fw-semibold">@Model.DiscountAmount.ToString("N0") VNĐ</span>
                    </div>
                    <hr />
                    <div class="d-flex justify-content-between">
                        <span class="serif fw-semibold">Tổng cộng</span>
                        <span class="text-gold fw-semibold">@Model.FinalAmount.ToString("N0") VNĐ</span>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
