@model IEnumerable<GodivaShop.Web.Models.Domain.Coupon>
@using GodivaShop.Web.Models.Domain

@{
    ViewData["Title"] = "Quản lý Mã Giảm Giá";
    
}

<div class="container-fluid pt-4 px-4">
    <div class="bg-light rounded p-4">
        <div class="d-flex align-items-center justify-content-between mb-4">
            <h4 class="mb-0 text-dark">Danh sách Mã Giảm Giá</h4>
            <button type="button" class="btn btn-primary" style="background-color: #cba052; border: none;" data-bs-toggle="modal" data-bs-target="#createCouponModal">
                + Tạo Mã Mới
            </button>
        </div>

        <div class="table-responsive">
            <table class="table text-start align-middle table-bordered table-hover mb-0">
                <thead class="text-dark" style="background-color: #fcfaf7;">
                    <tr>
                        <th>Mã Code</th>
                        <th>Khuyến Mãi</th>
                        <th>Đơn Tối Thiểu</th>
                        <th>Đã Dùng</th>
                        <th>Hạn Sử Dụng</th>
                        <th>Trạng Thái</th>
                        <th class="text-center">Hành Động</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td><strong class="text-uppercase">@item.Code</strong></td>
                            <td>
                                @if (item.DiscountType == DiscountType.Percentage)
                                {
                                    <span class="text-danger fw-bold">-@item.DiscountValue.ToString("0.##")%</span>
                                }
                                else
                                {
                                    <span class="text-danger fw-bold">-@item.DiscountValue.ToString("N0") đ</span>
                                }
                            </td>
                            <td>@(item.MinOrderAmount?.ToString("N0") + " đ" ?? "Không yêu cầu")</td>
                            <td>@item.UsedCount / @(item.MaxUsageCount?.ToString() ?? "∞")</td>
                            <td>
                                @if (item.ExpiryDate.HasValue)
                                {
                                    if (item.ExpiryDate.Value < DateTime.Now)
                                    {
                                        <span class="badge bg-danger">Hết hạn (@item.ExpiryDate.Value.ToString("dd/MM/yyyy"))</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-info">@item.ExpiryDate.Value.ToString("dd/MM/yyyy")</span>
                                    }
                                }
                                else
                                {
                                    <span>Vĩnh viễn</span>
                                }
                            </td>
                            <td>
                                @if (item.IsActive)
                                {
                                    <span class="badge bg-success">Đang Bật</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Đang Tắt</span>
                                }
                            </td>
                            <td class="text-center">
                                <form asp-action="Toggle" asp-route-id="@item.Id" method="post" style="display:inline;">
                                    <button type="submit" class="btn btn-sm @(item.IsActive ? "btn-outline-warning" : "btn-outline-success")" title="Bật/Tắt">
                                        <i class="fas @(item.IsActive ? "fa-eye-slash" : "fa-eye")"></i>
                                    </button>
                                </form>
                                <form asp-action="Delete" asp-route-id="@item.Id" method="post" style="display:inline;" onsubmit="return confirm('Bạn có chắc chắn muốn xóa mã @item.Code này không?');">
                                    <button type="submit" class="btn btn-sm btn-outline-danger" title="Xóa">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="createCouponModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header" style="background-color: #fcfaf7;">
                <h5 class="modal-title text-dark">Tạo Mã Giảm Giá Mới</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="Create" method="post">
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Mã Code (VD: GODIVA2026)</label>
                        <input type="text" name="Code" class="form-control text-uppercase" required>
                    </div>
                    
                    <div class="row mb-3">
                        <div class="col-6">
                            <label class="form-label">Loại Giảm</label>
                            <select name="DiscountType" class="form-select">
                                <option value="Percentage">Theo Phần Trăm (%)</option>
                                <option value="FixedAmount">Trừ Thẳng Tiền (VNĐ)</option>
                            </select>
                        </div>
                        <div class="col-6">
                            <label class="form-label">Mức Giảm</label>
                            <input type="number" name="DiscountValue" class="form-control" required min="1">
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Đơn Hàng Tối Thiểu (VNĐ) - <i>Tùy chọn</i></label>
                        <input type="number" name="MinOrderAmount" class="form-control" placeholder="Để trống nếu không yêu cầu">
                    </div>

                    <div class="row mb-3">
                        <div class="col-6">
                            <label class="form-label">Giới Hạn Lượt Dùng</label>
                            <input type="number" name="MaxUsageCount" class="form-control" placeholder="Để trống = Vô hạn">
                        </div>
                        <div class="col-6">
                            <label class="form-label">Ngày Hết Hạn</label>
                            <input type="date" name="ExpiryDate" class="form-control">
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-primary" style="background-color: #cba052; border: none;">Lưu Mã</button>
                </div>
            </form>
        </div>
    </div>
</div>