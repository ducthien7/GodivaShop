@model GodivaShop.Web.Models.ViewModels.ProductCreateViewModel
@{
    ViewData["Title"] = $"Chỉnh Sửa Sản Phẩm";
}

<div class="row g-4">
    <div class="col-md-8">
        <div style="background:#fff; padding:2rem; margin-bottom:1.5rem;">
            <p class="small text-uppercase mb-4"
                   style="letter-spacing:2px; color:#999; font-size:0.7rem;">
                Thông Tin Sản Phẩm
            </p>

            <form asp-area="Admin"
                  asp-controller="Product"
                  asp-action="Edit"
                  method="post"
                  enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id">

                    <div class="row g-3">
                        <div class="col-12">
                            <label class="small text-uppercase mb-1"
                                   style="letter-spacing:1px;">Tên Sản Phẩm</label>
                            <input asp-for="Name" class="form-control admin-form-control">
                                <span asp-validation-for="Name"
                                      class="text-danger" style="font-size:0.75rem;"></span>
                            </div>

                            <div class="col-md-6">
                                <label class="small text-uppercase mb-1"
                                       style="letter-spacing:1px;">Danh Mục</label>
                                <select asp-for="CategoryId"
                                        class="form-select admin-form-control">
                                    @foreach (var cat in
                                                                    (IEnumerable<GodivaShop.Web.Models.Domain.Category>)ViewBag.Categories)
                                    {
                                        <option value="@cat.Id">@cat.Name</option>
                                    }
                                </select>
                            </div>

                            <div class="col-md-6">
                                <label class="small text-uppercase mb-1"
                                       style="letter-spacing:1px;">Giá Gốc (VNĐ)</label>
                                <input asp-for="BasePrice"
                                       type="number"
                                       class="form-control admin-form-control">
                                </div>

                                <div class="col-12">
                                    <label class="small text-uppercase mb-1"
                                           style="letter-spacing:1px;">Mô Tả</label>
                                    <textarea asp-for="Description"
                                              class="form-control admin-form-control"
                                              rows="3"></textarea>
                                </div>

                                <div class="col-6">
                                    <div class="form-check">
                                        <input asp-for="IsBestSeller"
                                               class="form-check-input" type="checkbox">
                                            <label asp-for="IsBestSeller"
                                                   class="form-check-label small">Best Seller</label>
                                        </div>
                                    </div>
                                    <div class="col-6">
                                        <div class="form-check">
                                            <input asp-for="IsActive"
                                                   class="form-check-input" type="checkbox">
                                                <label asp-for="IsActive"
                                                       class="form-check-label small">
                                                    Hiển thị trên website
                                                </label>
                                            </div>
                                        </div>

                                        <div class="col-12">
                                            <label class="small text-uppercase mb-1"
                                                   style="letter-spacing:1px;">Thêm Ảnh Mới</label>
                                            <input type="file"
                                                   name="Images"
                                                   multiple
                                                   class="form-control admin-form-control"
                                                   accept="image/*">
                                        </div>
                                    </div>

                                    <button type="submit" class="btn btn-admin-gold mt-3 px-5">
                                        <i class="fa fa-save me-2"></i>Lưu Thay Đổi
                                    </button>
                                </form>
                            </div>

                            <!-- QUẢN LÝ ẢNH HIỆN TẠI -->
                            @if (ViewBag.ExistingImages != null)
                            {
                                <div style="background:#fff; padding:1.5rem; margin-bottom:1.5rem;">
                                    <p class="small text-uppercase mb-3"
                                           style="letter-spacing:2px; color:#999; font-size:0.7rem;">
                                        Ảnh Hiện Tại
                                    </p>
                                    <div class="d-flex gap-2 flex-wrap" id="imageList">
                                        @foreach (var img in (IEnumerable<GodivaShop.Web.Models.Domain.ProductImage>)ViewBag.ExistingImages)
                                        {
                                            <div style="position:relative;" id="img-@img.Id">
                                                <img src="@Url.Content(img.ImagePath)"
                                                     style="width:90px; height:90px; object-fit:cover;
                                                border:2px solid @(img.IsMain ? "var(--gold)" : "#eee");"
                                                     onerror="this.src='https://via.placeholder.com/90'">
                                                @if (img.IsMain)
                                                {
                                                    <span style="position:absolute; top:0; left:0;
                                                    background:var(--gold); color:#fff;
                                                    font-size:0.55rem; padding:2px 4px;">MAIN</span>
                                                }
                                                <div style="position:absolute; top:0; right:0;
                                                    display:flex; flex-direction:column; gap:1px;">
                                                    <button type="button"
                                                            onclick="setMainImage(@img.Id, @Model.Id)"
                                                            title="Đặt làm ảnh chính"
                                                            style="background:var(--gold); color:#fff;
                                                        border:none; width:20px; height:20px;
                                                        font-size:0.6rem; cursor:pointer;">
                                                        ★
                                                    </button>
                                                    <button type="button"
                                                            onclick="deleteImage(@img.Id)"
                                                            title="Xóa ảnh"
                                                            style="background:#e74c3c; color:#fff;
                                                        border:none; width:20px; height:20px;
                                                        font-size:0.7rem; cursor:pointer;">
                                                        ×
                                                    </button>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                </div>
                            }

                            <!-- QUẢN LÝ BIẾN THỂ -->
                            <div style="background:#fff; padding:1.5rem;">
                                <p class="small text-uppercase mb-3"
                                       style="letter-spacing:2px; color:#999; font-size:0.7rem;">
                                    Biến Thể (Size / Số Lượng)
                                </p>
                                <div id="variantList" class="mb-3">
                                    @if (ViewBag.Variants != null)
                                    {
                                        @foreach (var v in (IEnumerable<GodivaShop.Web.Models.Domain.ProductVariant>)ViewBag.Variants)
                                        {
                                            <div class="d-flex align-items-center gap-3 mb-2 p-2"
                                                 style="background:#faf8f5;" id="variant-@v.Id">
                                                <span class="flex-grow-1 small fw-semibold">@v.Name</span>
                                                <span class="text-gold small">@v.Price.ToString("N0")đ</span>
                                                <span class="text-muted small">Tồn: @v.StockQuantity</span>
                                                <button type="button"
                                                        onclick="deleteVariant(@v.Id)"
                                                        class="btn btn-sm"
                                                        style="border:1px solid #e74c3c; color:#e74c3c;
                                                    border-radius:0; padding:2px 8px;">
                                                    <i class="fa fa-trash"></i>
                                                </button>
                                            </div>
                                        }
                                    }
                                </div>

                                <!-- Form thêm biến thể -->
                                <div style="background:#faf8f5; padding:1rem;">
                                    <p class="small mb-2"
                                           style="letter-spacing:1px; text-transform:uppercase;
                                        font-size:0.7rem; color:#999;">
                                        Thêm Biến Thể Mới
                                    </p>
                                    <div class="row g-2">
                                        <div class="col-md-4">
                                            <input type="text" id="vName"
                                                   class="form-control admin-form-control"
                                                   placeholder="Tên (VD: 8 viên)">
                                        </div>
                                        <div class="col-md-3">
                                            <input type="number" id="vPrice"
                                                   class="form-control admin-form-control"
                                                   placeholder="Giá (VNĐ)">
                                        </div>
                                        <div class="col-md-3">
                                            <input type="number" id="vStock"
                                                   class="form-control admin-form-control"
                                                   placeholder="Tồn kho">
                                        </div>
                                        <div class="col-md-2">
                                            <button type="button"
                                                    class="btn btn-admin-gold w-100"
                                                    onclick="addVariant(@Model.Id)">
                                                <i class="fa fa-plus"></i>
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- XEM TRƯỚC -->
                        <div class="col-md-4">
                            <div style="background:#faf8f5; padding:1.5rem; position:sticky; top:80px;">
                                <p class="small text-uppercase mb-3"
                                       style="letter-spacing:2px; color:#999; font-size:0.7rem;">
                                    Xem Trước
                                </p>
                                @if (ViewBag.ExistingImages != null)
                                {
                                    var firstImg = ((IEnumerable<GodivaShop.Web.Models.Domain.ProductImage>)ViewBag.ExistingImages)
                                        .FirstOrDefault(i => i.IsMain)
                                        ?? ((IEnumerable<GodivaShop.Web.Models.Domain.ProductImage>)ViewBag.ExistingImages)
                                        .FirstOrDefault();
                                    if (firstImg != null)
                                    {
                                        <img src="@Url.Content(firstImg.ImagePath)"
                                             style="width:100%; height:200px; object-fit:cover;"
                                             class="mb-3"
                                             onerror="this.src='https://via.placeholder.com/300x200'">
                                    }
                                }
                                <h6 class="serif mb-1">@Model.Name</h6>
                                <p class="text-gold mb-3">@Model.BasePrice.ToString("N0") VNĐ</p>
                                <a href="/Product/Detail/@Model.Id"
                                       target="_blank"
                                       class="btn btn-admin-outline btn-sm w-100">
                                    <i class="fa fa-eye me-1"></i> Xem ngoài website
                                </a>
                            </div>
                        </div>
                    </div>

                    @section Scripts {
                        <script>
                            function deleteImage(id) {
                                if (!confirm('Xóa ảnh này?')) return;
                                fetch('/Admin/Product/DeleteImage', {
                                    method: 'POST',
                                    headers: { 'Content-Type': 'application/x-www-form-urlencoded',
                                               'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value },
                                    body: `id=${id}`
                                }).then(r => r.json()).then(res => {
                                    if (res.success)
                                        document.getElementById(`img-${id}`).remove();
                                });
                            }

                            function setMainImage(imageId, productId) {
                                fetch('/Admin/Product/SetMainImage', {
                                    method: 'POST',
                                    headers: { 'Content-Type': 'application/x-www-form-urlencoded',
                                               'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value },
                                    body: `imageId=${imageId}&productId=${productId}`
                                }).then(r => r.json()).then(res => {
                                    if (res.success) location.reload();
                                });
                            }

                            function addVariant(productId) {
                                const name  = document.getElementById('vName').value.trim();
                                const price = document.getElementById('vPrice').value;
                                const stock = document.getElementById('vStock').value || 0;
                                if (!name || !price) { alert('Vui lòng nhập tên và giá!'); return; }

                                fetch('/Admin/Product/AddVariant', {
                                    method: 'POST',
                                    headers: { 'Content-Type': 'application/x-www-form-urlencoded',
                                               'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value },
                                    body: `productId=${productId}&name=${encodeURIComponent(name)}&price=${price}&stockQuantity=${stock}`
                                }).then(r => r.json()).then(res => {
                                    if (res.success) {
                                        document.getElementById('variantList').innerHTML += `
                                            <div class="d-flex align-items-center gap-3 mb-2 p-2"
                                                 style="background:#faf8f5;" id="variant-${res.id}">
                                                <span class="flex-grow-1 small fw-semibold">${name}</span>
                                                <span class="text-gold small">${parseFloat(price).toLocaleString('vi-VN')}đ</span>
                                                <span class="text-muted small">Tồn: ${stock}</span>
                                                <button type="button" onclick="deleteVariant(${res.id})"
                                                        class="btn btn-sm"
                                                        style="border:1px solid #e74c3c; color:#e74c3c; border-radius:0; padding:2px 8px;">
                                                    <i class="fa fa-trash"></i>
                                                </button>
                                            </div>`;
                                        document.getElementById('vName').value  = '';
                                        document.getElementById('vPrice').value = '';
                                        document.getElementById('vStock').value = '';
                                    }
                                });
                            }

                            function deleteVariant(id) {
                                if (!confirm('Xóa biến thể này?')) return;
                                fetch('/Admin/Product/DeleteVariant', {
                                    method: 'POST',
                                    headers: { 'Content-Type': 'application/x-www-form-urlencoded',
                                               'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value },
                                    body: `id=${id}`
                                }).then(r => r.json()).then(res => {
                                    if (res.success)
                                        document.getElementById(`variant-${id}`).remove();
                                });
                            }
                        </script>
                    }