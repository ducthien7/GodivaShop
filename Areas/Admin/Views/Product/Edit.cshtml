@model GodivaShop.Web.Models.Domain.Product
@{
    ViewData["Title"] = $"Chỉnh Sửa: {Model.Name}"; Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="row g-4">
    <div class="col-md-8">
        <!-- FORM SỬA THÔNG TIN -->
        <div style="background:#fff; padding:2rem; margin-bottom:1.5rem;">
            <p class="small text-uppercase mb-4" style="letter-spacing:2px; color:#999; font-size:0.7rem;">Thông Tin Sản Phẩm</p>
            <form asp-area="Admin" asp-controller="Product" asp-action="Edit"
                  method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id">
                <div class="row g-3">
                    <div class="col-12">
                        <label class="small text-uppercase mb-1" style="letter-spacing:1px;">Tên Sản Phẩm</label>
                        <input asp-for="Name" class="form-control admin-form-control">
                    </div>
                    <div class="col-md-6">
                        <label class="small text-uppercase mb-1" style="letter-spacing:1px;">Danh Mục</label>
                        <select asp-for="CategoryId" class="form-select admin-form-control">
                            @foreach (var cat in (IEnumerable<GodivaShop.Web.Models.Domain.Category>)ViewBag.Categories)
                            {
                                <option value="@cat.Id">@cat.Name</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="small text-uppercase mb-1" style="letter-spacing:1px;">Giá Gốc</label>
                        <input asp-for="BasePrice" type="number" class="form-control admin-form-control">
                    </div>
                    <div class="col-12">
                        <label class="small text-uppercase mb-1" style="letter-spacing:1px;">Mô Tả</label>
                        <textarea asp-for="Description" class="form-control admin-form-control" rows="3"></textarea>
                    </div>
                    <div class="col-6">
                        <div class="form-check">
                            <input asp-for="IsBestSeller" class="form-check-input" type="checkbox">
                            <label class="form-check-label small">Best Seller</label>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="form-check">
                            <input asp-for="IsActive" class="form-check-input" type="checkbox">
                            <label class="form-check-label small">Đang hiển thị</label>
                        </div>
                    </div>
                    <div class="col-12">
                        <label class="small text-uppercase mb-1" style="letter-spacing:1px;">Thêm Ảnh Mới</label>
                        <input type="file" name="newImages" multiple class="form-control admin-form-control" accept="image/*">
                    </div>
                </div>
                <button type="submit" class="btn btn-admin-gold mt-3 px-5">
                    <i class="fa fa-save me-2"></i>Lưu Thay Đổi
                </button>
            </form>
        </div>

        <!-- QUẢN LÝ ẢNH -->
        <div style="background:#fff; padding:2rem; margin-bottom:1.5rem;">
            <p class="small text-uppercase mb-3" style="letter-spacing:2px; color:#999; font-size:0.7rem;">Ảnh Sản Phẩm</p>
            <div class="d-flex gap-2 flex-wrap" id="imageList">
                @foreach (var img in Model.Images)
                {
                    <div style="position:relative;" id="img-@img.Id">
                        <img src="@Url.Content(img.ImagePath)" style="width:90px; height:90px; object-fit:cover; border:2px solid @(img.IsMain ? "var(--gold)" : "#eee");">
                        @if (img.IsMain)
                        {
                            <span style="position:absolute; top:0; left:0; background:var(--gold); color:#fff; font-size:0.55rem; padding:2px 4px;">MAIN</span>
                        }
                        <button type="button" onclick="deleteImage(@img.Id)"
                                style="position:absolute; top:0; right:0; background:#e74c3c; color:#fff; border:none; width:20px; height:20px; font-size:0.7rem; display:flex; align-items:center; justify-content:center;">
                            ×
                        </button>
                    </div>
                }
            </div>
        </div>

        <!-- QUẢN LÝ BIẾN THỂ -->
        <div style="background:#fff; padding:2rem;">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <p class="small text-uppercase mb-0" style="letter-spacing:2px; color:#999; font-size:0.7rem;">Biến Thể (Size / Số Lượng)</p>
            </div>
            <div id="variantList" class="mb-3">
                @foreach (var v in Model.Variants)
                {
                    <div class="d-flex align-items-center gap-2 mb-2 p-2" style="background:#faf8f5;" id="variant-@v.Id">
                        <span class="flex-grow-1 small fw-semibold">@v.Name</span>
                        <span class="text-gold small">@v.Price.ToString("N0")đ</span>
                        <span class="text-muted small">Tồn: @v.StockQuantity</span>
                        <button type="button" onclick="deleteVariant(@v.Id)"
                                class="btn btn-sm" style="border:1px solid #e74c3c; color:#e74c3c; border-radius:0; padding:2px 8px;">
                            <i class="fa fa-trash"></i>
                        </button>
                    </div>
                }
            </div>
            <!-- FORM THÊM BIẾN THỂ -->
            <div style="background:#faf8f5; padding:1rem;">
                <p class="small mb-2" style="letter-spacing:1px; text-transform:uppercase; font-size:0.7rem;">Thêm Biến Thể Mới</p>
                <div class="row g-2">
                    <div class="col-md-4">
                        <input type="text" id="vName" class="form-control admin-form-control" placeholder="Tên (VD: 8 viên)">
                    </div>
                    <div class="col-md-3">
                        <input type="number" id="vPrice" class="form-control admin-form-control" placeholder="Giá (VNĐ)">
                    </div>
                    <div class="col-md-3">
                        <input type="number" id="vStock" class="form-control admin-form-control" placeholder="Số lượng tồn">
                    </div>
                    <div class="col-md-2">
                        <button class="btn btn-admin-gold w-100" onclick="addVariant(@Model.Id)">
                            <i class="fa fa-plus"></i>
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div style="background:#faf8f5; padding:1.5rem; position:sticky; top:80px;">
            <p class="small text-uppercase mb-3" style="letter-spacing:2px; color:#999; font-size:0.7rem;">Xem Trước</p>
            <img src="@Url.Content(Model.Images.FirstOrDefault(i=>i.IsMain)?.ImagePath ?? Model.Images.FirstOrDefault()?.ImagePath ?? "")"
                 style="width:100%; height:200px; object-fit:cover;" class="mb-3"
                 onerror="this.src='https://images.unsplash.com/photo-1549007994-cb92caebd54b?w=300'">
            <h6 class="serif">@Model.Name</h6>
            <p class="text-gold mb-1">@Model.BasePrice.ToString("N0") VNĐ</p>
            <div class="d-flex gap-2 mt-2">
                <a asp-controller="Product" asp-action="Detail" asp-route-id="@Model.Id"
                   target="_blank" class="btn btn-admin-outline btn-sm">
                    <i class="fa fa-eye me-1"></i> Xem Website
                </a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function deleteImage(id) {
            if (!confirm('Xóa ảnh này?')) return;
            $.post('/Admin/Product/DeleteImage', { id }, function(res) {
                if (res.success) $(`#img-${id}`).fadeOut(300, function() { $(this).remove(); });
            });
        }

        function addVariant(productId) {
            const name = $('#vName').val().trim();
            const price = parseFloat($('#vPrice').val());
            const stock = parseInt($('#vStock').val()) || 0;
            if (!name || !price) { alert('Vui lòng nhập đủ tên và giá!'); return; }

            $.ajax({
                url: '/Admin/Product/AddVariant', method: 'POST',
                data: { productId, name, price, stockQuantity: stock, isActive: true },
                success: function(res) {
                    if (res.success) {
                        $('#variantList').append(`
                            <div class="d-flex align-items-center gap-2 mb-2 p-2" style="background:#faf8f5;" id="variant-${res.id}">
                                <span class="flex-grow-1 small fw-semibold">${name}</span>
                                <span class="text-gold small">${price.toLocaleString('vi-VN')}đ</span>
                                <span class="text-muted small">Tồn: ${stock}</span>
                                <button type="button" onclick="deleteVariant(${res.id})"
                                    class="btn btn-sm" style="border:1px solid #e74c3c; color:#e74c3c; border-radius:0; padding:2px 8px;">
                                    <i class="fa fa-trash"></i>
                                </button>
                            </div>`);
                        $('#vName').val(''); $('#vPrice').val(''); $('#vStock').val('');
                    }
                }
            });
        }

        function deleteVariant(id) {
            if (!confirm('Xóa biến thể này?')) return;
            $.post('/Admin/Product/DeleteVariant', { id }, function(res) {
                if (res.success) $(`#variant-${id}`).fadeOut(300, function() { $(this).remove(); });
            });
        }
    </script>
}