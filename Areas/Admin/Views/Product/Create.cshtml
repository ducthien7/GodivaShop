@model GodivaShop.Web.Models.ViewModels.ProductCreateViewModel
@{
    ViewData["Title"] = "Thêm Sản Phẩm Mới";
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger" style="border-radius:0;">
        <i class="fa fa-exclamation-triangle me-2"></i>@TempData["Error"]
    </div>
}

<div class="row g-4">
    <div class="col-md-8">
        <div style="background:#fff; padding:2rem;">
            <p class="small text-uppercase mb-4"
                   style="letter-spacing:2px; color:#999; font-size:0.7rem;">
                Thông Tin Sản Phẩm
            </p>

            <form asp-area="Admin"
                  asp-controller="Product"
                  asp-action="Create"
                  method="post"
                  enctype="multipart/form-data">
                @Html.AntiForgeryToken()

                <div class="row g-3">
                    <div class="col-12">
                        <label class="small text-uppercase mb-1"
                               style="letter-spacing:1px;">Tên Sản Phẩm *</label>
                        <input asp-for="Name"
                               class="form-control admin-form-control"
                               placeholder="VD: Dark Chocolate 70%">
                            <span asp-validation-for="Name"
                                  class="text-danger" style="font-size:0.75rem;"></span>
                        </div>

                        <div class="col-md-6">
                            <label class="small text-uppercase mb-1"
                                   style="letter-spacing:1px;">Danh Mục *</label>
                            <select asp-for="CategoryId"
                                    class="form-select admin-form-control">
                                <option value="">-- Chọn danh mục --</option>
                                @foreach (var cat in
                                                                (IEnumerable<GodivaShop.Web.Models.Domain.Category>)ViewBag.Categories)
                                {
                                    <option value="@cat.Id">@cat.Name</option>
                                }
                            </select>
                            <span asp-validation-for="CategoryId"
                                  class="text-danger" style="font-size:0.75rem;"></span>
                        </div>

                        <div class="col-md-6">
                            <label class="small text-uppercase mb-1"
                                   style="letter-spacing:1px;">Giá Gốc (VNĐ) *</label>
                            <input asp-for="BasePrice"
                                   type="number"
                                   class="form-control admin-form-control"
                                   placeholder="VD: 350000">
                                <span asp-validation-for="BasePrice"
                                      class="text-danger" style="font-size:0.75rem;"></span>
                            </div>

                            <div class="col-12">
                                <label class="small text-uppercase mb-1"
                                       style="letter-spacing:1px;">Mô Tả Sản Phẩm</label>
                                <textarea asp-for="Description"
                                          class="form-control admin-form-control"
                                          rows="4"
                                          placeholder="Mô tả chi tiết sản phẩm..."></textarea>
                            </div>

                            <div class="col-md-6">
                                <div class="form-check mt-2">
                                    <input asp-for="IsBestSeller"
                                           class="form-check-input" type="checkbox">
                                        <label asp-for="IsBestSeller"
                                               class="form-check-label small">
                                            Đánh dấu Best Seller ⭐
                                        </label>
                                    </div>
                                </div>

                                <div class="col-md-6">
                                    <div class="form-check mt-2">
                                        <input asp-for="IsActive"
                                               class="form-check-input" type="checkbox"
                                               checked>
                                            <label asp-for="IsActive"
                                                   class="form-check-label small">
                                                Hiển thị trên website
                                            </label>
                                        </div>
                                    </div>

                                    <!-- UPLOAD ẢNH -->
                                    <div class="col-12">
                                        <label class="small text-uppercase mb-2"
                                               style="letter-spacing:1px;">Ảnh Sản Phẩm</label>
                                        <div id="dropZone"
                                             style="border:2px dashed #ddd; padding:2.5rem;
                                            text-align:center; cursor:pointer;
                                            transition:all 0.2s; background:#fafafa;"
                                             onclick="document.getElementById('imageUpload').click()">
                                            <i class="fa fa-cloud-upload-alt fa-2x mb-2 text-muted"></i>
                                            <p class="text-muted small mb-1">
                                                Click hoặc kéo thả ảnh vào đây
                                            </p>
                                            <p class="text-muted mb-0" style="font-size:0.7rem;">
                                                JPG, PNG — Ảnh đầu tiên là ảnh chính
                                            </p>
                                        </div>
                                        <input type="file"
                                               id="imageUpload"
                                               name="Images"
                                               multiple
                                               accept="image/*"
                                               style="display:none"
                                               onchange="previewImages(this)">
                                        <div id="imagePreview"
                                             class="d-flex gap-2 flex-wrap mt-2"></div>
                                    </div>
                                </div>

                                <div class="d-flex gap-2 mt-4">
                                    <button type="submit" class="btn btn-admin-gold px-5">
                                        <i class="fa fa-save me-2"></i>Lưu Sản Phẩm
                                    </button>
                                    <a asp-area="Admin"
                                       asp-controller="Product"
                                       asp-action="Index"
                                       class="btn btn-admin-outline px-4">Hủy</a>
                                </div>
                            </form>
                        </div>
                    </div>

                    <!-- HƯỚNG DẪN -->
                    <div class="col-md-4">
                        <div style="background:#faf8f5; padding:1.5rem;">
                            <p class="small text-uppercase mb-3"
                                   style="letter-spacing:2px; color:#999; font-size:0.7rem;">
                                Lưu Ý
                            </p>
                            <ul class="small text-muted ps-3">
                                <li class="mb-2">
                                    Ảnh đầu tiên tự động là <strong>ảnh chính</strong>
                                </li>
                                <li class="mb-2">
                                    Nên upload ít nhất <strong>3-5 ảnh</strong> chất lượng cao
                                </li>
                                <li class="mb-2">
                                    Biến thể (size, giá) thêm sau khi tạo xong sản phẩm
                                </li>
                                <li class="mb-2">
                                    Tick <strong>"Hiển thị"</strong> để sản phẩm xuất hiện ngoài website
                                </li>
                                <li>Dung lượng tối đa mỗi ảnh: <strong>5MB</strong></li>
                            </ul>
                        </div>

                        @if (TempData["Success"] != null)
                        {
                            <div class="alert alert-success mt-3" style="border-radius:0;">
                                <i class="fa fa-check me-2"></i>@TempData["Success"]
                            </div>
                        }
                    </div>
                </div>

                @section Scripts {
                    <script>
                        function previewImages(input) {
                            const preview = document.getElementById('imagePreview');
                            preview.innerHTML = '';
                            Array.from(input.files).forEach((file, idx) => {
                                const reader = new FileReader();
                                reader.onload = e => {
                                    preview.innerHTML += `
                                        <div style="position:relative; display:inline-block;">
                                            <img src="${e.target.result}"
                                                 style="width:85px; height:85px; object-fit:cover;
                                                        border:2px solid ${idx === 0 ? 'var(--gold)' : '#ddd'};">
                                            ${idx === 0
                                                ? '<span style="position:absolute;top:0;left:0;background:var(--gold);color:#fff;font-size:0.55rem;padding:2px 5px;">MAIN</span>'
                                                : ''}
                                        </div>`;
                                };
                                reader.readAsDataURL(file);
                            });
                        }

                        // Drag & Drop
                        const dropZone = document.getElementById('dropZone');
                        dropZone.addEventListener('dragover', e => {
                            e.preventDefault();
                            dropZone.style.borderColor = 'var(--gold)';
                            dropZone.style.background = '#fdf9f0';
                        });
                        dropZone.addEventListener('dragleave', () => {
                            dropZone.style.borderColor = '#ddd';
                            dropZone.style.background = '#fafafa';
                        });
                        dropZone.addEventListener('drop', e => {
                            e.preventDefault();
                            dropZone.style.borderColor = '#ddd';
                            dropZone.style.background = '#fafafa';
                            const input = document.getElementById('imageUpload');
                            input.files = e.dataTransfer.files;
                            previewImages(input);
                        });
                    </script>
                }