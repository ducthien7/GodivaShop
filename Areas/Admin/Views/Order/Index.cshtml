@model IEnumerable<GodivaShop.Web.Models.Domain.Order>
@using GodivaShop.Web.Models.Domain
@{
    ViewData["Title"] = "Quản Lý Đơn Hàng"; Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

@section Styles {
    <style>
        .filter-tabs .btn { border-radius: 0; font-size: 0.75rem; letter-spacing: 1px; text-transform: uppercase; }
        .filter-tabs .btn.active { background: var(--gold); color: #fff; border-color: var(--gold); }
    </style>
}

<!-- FILTER TABS -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <div class="filter-tabs btn-group" role="group">
        <button type="button" class="btn btn-outline-secondary active" onclick="filterOrders('all', this)">Tất Cả</button>
        <button type="button" class="btn btn-outline-secondary" onclick="filterOrders('guest', this)">Vãng Lai</button>
        <button type="button" class="btn btn-outline-secondary" onclick="filterOrders('member', this)">Thành Viên</button>
        <button type="button" class="btn btn-outline-secondary" onclick="filterOrders('pending', this)">Chờ Xử Lý</button>
    </div>
    <div class="input-group" style="width:280px;">
        <input type="text" class="form-control admin-form-control" placeholder="Tìm kiếm đơn hàng..." id="searchInput" oninput="searchOrders()">
        <span class="input-group-text" style="border-radius:0; background:#fff;"><i class="fa fa-search text-muted"></i></span>
    </div>
</div>

<div style="background:#fff;">
    <table class="table admin-table mb-0" id="orderTable">
        <thead>
            <tr>
                <th>#ID</th>
                <th>Khách Hàng</th>
                <th>Liên Hệ</th>
                <th>Địa Chỉ</th>
                <th>Loại KH</th>
                <th>Tổng Tiền</th>
                <th>Trạng Thái</th>
                <th>Ngày Đặt</th>
                <th>Thao Tác</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var order in Model)
            {
                <tr class="order-row"
                    data-type="@(order.UserId == null ? "guest" : "member")"
                    data-status="@order.Status.ToString().ToLower()"
                    data-search="@($"{order.Id} {order.GuestFullName} {order.GuestEmail} {order.GuestPhone}".ToLower())">
                    <td class="text-gold fw-semibold">#@order.Id</td>
                    <td>
                        <div class="fw-semibold" style="font-size:0.85rem;">@order.GuestFullName</div>
                        <div class="text-muted" style="font-size:0.75rem;">@order.GuestEmail</div>
                    </td>
                    <td style="font-size:0.8rem;">@order.GuestPhone</td>
                    <td style="font-size:0.8rem; max-width:160px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">
                        @order.ShippingAddress
                    </td>
                    <td>
                        @if (order.UserId == null)
                        {
                            <span class="badge" style="background:#f0ebe0; color:#C1A35E; font-size:0.65rem; font-weight:400;">Vãng Lai</span>
                        }
                        else
                        {
                            <span class="badge" style="background:#e8f0e8; color:#2d6a2d; font-size:0.65rem; font-weight:400;">Thành Viên</span>
                        }
                    </td>
                    <td class="text-gold fw-semibold">@(order.TotalAmount - order.DiscountAmount).ToString("N0")đ</td>
                    <td>
                        <span class="badge-status badge-@order.Status.ToString().ToLower()">
                            @order.Status switch {
                            OrderStatus.Pending => "Chờ xử lý",
                            OrderStatus.Confirmed => "Đã xác nhận",
                            OrderStatus.Processing => "Đang xử lý",
                            OrderStatus.Shipped => "Đang giao",
                            OrderStatus.Delivered => "Đã giao",
                            OrderStatus.Cancelled => "Đã hủy",
                            _ => order.Status.ToString()
                            }
                        </span>
                    </td>
                    <td class="text-muted" style="font-size:0.8rem;">@order.OrderDate.ToString("dd/MM/yy HH:mm")</td>
                    <td>
                        <div class="d-flex gap-1">
                            <a asp-area="Admin" asp-controller="Order" asp-action="Detail" asp-route-id="@order.Id"
                               class="btn btn-sm btn-admin-outline" title="Chi tiết">
                                <i class="fa fa-eye"></i>
                            </a>
                            <div class="dropdown">
                                <button class="btn btn-sm btn-admin-gold dropdown-toggle" data-bs-toggle="dropdown">
                                    <i class="fa fa-edit"></i>
                                </button>
                                <ul class="dropdown-menu" style="border-radius:0; font-size:0.8rem; min-width:160px;">
                                    @foreach (OrderStatus status in Enum.GetValues(typeof(OrderStatus)))
                                    {
                                        <li>
                                            <form asp-area="Admin" asp-controller="Order" asp-action="UpdateStatus" method="post" class="d-inline">
                                                <input type="hidden" name="id" value="@order.Id">
                                                <input type="hidden" name="status" value="@status">
                                                <button type="submit" class="dropdown-item @(order.Status == status ? "active" : "")">
                                                    @status switch {
                                                    OrderStatus.Pending => "⏳ Chờ xử lý",
                                                    OrderStatus.Confirmed => "✅ Xác nhận",
                                                    OrderStatus.Processing => "⚙️ Đang xử lý",
                                                    OrderStatus.Shipped => "🚚 Đang giao",
                                                    OrderStatus.Delivered => "✔️ Đã giao",
                                                    OrderStatus.Cancelled => "❌ Hủy đơn",
                                                    _ => status.ToString()
                                                    }
                                                </button>
                                            </form>
                                        </li>
                                    }
                                </ul>
                            </div>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
    <script>
        function filterOrders(type, btn) {
            $('.filter-tabs .btn').removeClass('active');
            $(btn).addClass('active');
            $('.order-row').each(function() {
                if (type === 'all') { $(this).show(); return; }
                const rowType = $(this).data('type');
                const rowStatus = $(this).data('status');
                if (type === 'guest' && rowType === 'guest') $(this).show();
                else if (type === 'member' && rowType === 'member') $(this).show();
                else if (type === 'pending' && rowStatus === 'pending') $(this).show();
                else $(this).hide();
            });
        }

        function searchOrders() {
            const term = $('#searchInput').val().toLowerCase();
            $('.order-row').each(function() {
                $(this).toggle($(this).data('search').includes(term));
            });
        }
    </script>
}