@page
@model GodivaShop.Web.Areas.Identity.Pages.Account.LoginModel
@{
    ViewData["Title"] = "Đăng Nhập";
    Layout = "/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <style>
        .auth-wrapper {
            min-height: 80vh;
            display: flex;
            align-items: center;
            background: linear-gradient(135deg, #faf8f5 0%, #fff 100%);
        }

        .auth-card {
            max-width: 460px;
            width: 100%;
            margin: 0 auto;
            padding: 3rem 2.5rem;
            background: #fff;
            border-top: 3px solid var(--gold);
            box-shadow: 0 10px 40px rgba(0,0,0,0.07);
        }

        .auth-title {
            font-family: 'Playfair Display', serif;
            font-size: 2rem;
            text-align: center;
            margin-bottom: 0.3rem;
            color: #1a1a1a;
        }

        .auth-subtitle {
            text-align: center;
            color: #aaa;
            font-size: 0.72rem;
            letter-spacing: 2.5px;
            text-transform: uppercase;
            margin-bottom: 2.5rem;
        }

        .form-control {
            border-radius: 0;
            border: 1px solid #e0e0e0;
            font-size: 0.875rem;
            padding: 10px 14px;
            transition: border-color 0.2s;
        }

            .form-control:focus {
                border-color: var(--gold);
                box-shadow: 0 0 0 3px rgba(193,163,94,0.1);
            }

        .form-label {
            font-size: 0.7rem;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            color: #888;
            margin-bottom: 6px;
        }

        .divider {
            display: flex;
            align-items: center;
            gap: 1rem;
            margin: 1.8rem 0;
        }

            .divider::before, .divider::after {
                content: '';
                flex: 1;
                height: 1px;
                background: #eee;
            }

            .divider span {
                font-size: 0.7rem;
                color: #bbb;
                letter-spacing: 1px;
                white-space: nowrap;
            }

        .btn-google {
            border: 1px solid #e0e0e0;
            background: #fff;
            color: #444;
            border-radius: 0;
            font-size: 0.82rem;
            padding: 11px;
            width: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            transition: border-color 0.2s, box-shadow 0.2s;
            cursor: pointer;
        }

            .btn-google:hover {
                border-color: var(--gold);
                box-shadow: 0 2px 8px rgba(193,163,94,0.15);
            }
    </style>
}

<div class="auth-wrapper py-5">
    <div class="auth-card">
        <div class="text-center mb-4">
            <a href="/" style="font-family:'Playfair Display',serif; font-size:1.5rem; color:var(--gold); letter-spacing:4px; text-decoration:none;">
                GODIVA
            </a>
        </div>

        <h2 class="auth-title">Đăng Nhập</h2>
        <p class="auth-subtitle">Chào mừng trở lại</p>

        <div asp-validation-summary="ModelOnly" class="alert alert-danger small py-2 mb-3" style="border-radius:0;"></div>

        <form method="post">
            @Html.AntiForgeryToken()

            <div class="mb-3">
                <label asp-for="Input.Email" class="form-label">Email</label>
                <input asp-for="Input.Email" class="form-control" placeholder="your@email.com" autocomplete="username">
                    <span asp-validation-for="Input.Email" class="text-danger" style="font-size:0.75rem;"></span>
                </div>

                <div class="mb-3">
                    <div class="d-flex justify-content-between align-items-center mb-1">
                        <label asp-for="Input.Password" class="form-label mb-0">Mật Khẩu</label>
                        <a asp-area="" asp-controller="Account" asp-action="ForgotPassword" style="font-size:0.72rem; color:var(--gold); text-decoration:none; letter-spacing:0.5px;">
                            Quên mật khẩu?
                        </a>
                    </div>
                    <input asp-for="Input.Password" class="form-control" placeholder="••••••••" autocomplete="current-password">
                        <span asp-validation-for="Input.Password" class="text-danger" style="font-size:0.75rem;"></span>
                    </div>

                    <div class="mb-4 d-flex align-items-center gap-2">
                        <input asp-for="Input.RememberMe" class="form-check-input mt-0" style="border-radius:0;">
                            <label asp-for="Input.RememberMe" class="form-check-label small text-muted">
                                Ghi nhớ đăng nhập
                            </label>
                        </div>

                        <button type="submit" class="btn btn-gold w-100 py-3" style="letter-spacing:2px; text-transform:uppercase; font-size:0.8rem;">
                            Đăng Nhập
                        </button>
                    </form>

                    @if (Model.ExternalLogins?.Any() == true)
                    {
                        <div class="divider"><span>Hoặc tiếp tục với</span></div>
            
                        <form asp-area="Identity" asp-page="/Account/ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                            @Html.AntiForgeryToken()
                            @foreach (var provider in Model.ExternalLogins)
                            {
                                @if (provider.Name == "Google")
                                {
                                    <button type="submit" name="provider" value="@provider.Name" class="btn-google">
                                        <svg width="18" height="18" viewBox="0 0 48 48">
                                            <path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z" />
                                            <path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z" />
                                            <path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z" />
                                            <path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z" />
                                        </svg>
                                        Tiếp tục với Google
                                    </button>
                                }
                            }
                        </form>
                    }

                    <p class="text-center small text-muted mt-4 mb-0">
                        Chưa có tài khoản?
                        <a href="/Identity/Account/Register" style="color:var(--gold); text-decoration:none; font-weight:600;">
                            Đăng ký miễn phí
                        </a>
                    </p>
                </div>
            </div>