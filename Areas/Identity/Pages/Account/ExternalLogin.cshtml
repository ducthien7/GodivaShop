@page
@model ExternalLoginModel
@{
    ViewData["Title"] = "Liên kết tài khoản";
}

<div class="container py-5 d-flex justify-content-center">
    <div class="card shadow-sm border-0" style="max-width: 550px; width: 100%; border-radius: 0;">
        <div class="card-body p-5">
            <div class="text-center mb-4">
                <h2 class="serif mb-2" style="font-size: 2rem; color: #333;">@ViewData["Title"]</h2>
                <p class="text-muted" style="font-size: 0.72rem; letter-spacing: 2px; text-transform: uppercase;">
                    Hoàn tất đăng nhập với @Model.ProviderDisplayName
                </p>
            </div>

            <div class="alert mb-4" style="background-color: #fdf9f0; border: 1px solid #e8d9b8; border-radius: 0; color: #555; font-size: 0.9rem; line-height: 1.6;">
                <i class="fa fa-check-circle me-2" style="color: #c1a35e;"></i>
                Xác thực tài khoản <strong>@Model.ProviderDisplayName</strong> thành công! <br />
                Vui lòng xác nhận lại địa chỉ Email bên dưới để hoàn tất việc đăng ký và liên kết tài khoản mua hàng.
            </div>

            <form asp-page-handler="Confirmation" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>
                
                <div class="mb-4">
                    <label asp-for="Input.Email" class="form-label" style="font-size: 0.72rem; letter-spacing: 1.5px; text-transform: uppercase; color: #888;">
                        Địa chỉ Email *
                    </label>
                    <input asp-for="Input.Email" class="form-control p-3" 
                           style="border-radius: 0; border: 1px solid #e0e0e0; font-size: 0.95rem; box-shadow: none;" 
                           placeholder="Nhập email của bạn..." />
                    <span asp-validation-for="Input.Email" class="text-danger mt-1 d-block" style="font-size: 0.75rem;"></span>
                </div>

                <button type="submit" class="btn w-100 py-3 text-white fw-bold" 
                        style="background-color: #c1a35e; border-color: #c1a35e; border-radius: 0; letter-spacing: 1.5px; text-transform: uppercase;">
                    <i class="fa fa-user-plus me-2"></i> Hoàn Tất Đăng Ký
                </button>
                
                <div class="text-center mt-4">
                    <a href="~/" class="text-muted" style="font-size: 0.85rem; text-decoration: none;">
                        <i class="fa fa-arrow-left me-1"></i> Quay lại trang chủ
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    
    <style>
        /* Hiệu ứng focus cho input đồng bộ với theme Godiva */
        .form-control:focus {
            border-color: #c1a35e !important;
            box-shadow: 0 0 0 3px rgba(193, 163, 94, 0.2) !important;
        }
        .btn:hover {
            background-color: #a88d4d !important;
            border-color: #a88d4d !important;
        }
    </style>
}